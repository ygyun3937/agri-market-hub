# Database
DB_PASS=your_db_password

# JWT
JWT_SECRET=your_jwt_secret_base64

# 기상청 API (https://www.data.go.kr)
WEATHER_KEY=your_weather_api_key

# KAMIS 농산물 가격 API (https://www.kamis.or.kr)
KAMIS_KEY=your_kamis_api_key

# 네이버 뉴스 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# VAPID (Web Push) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# 농촌진흥청 병해충 API (https://www.data.go.kr)
PEST_KEY=your_pest_api_key

# 오피넷 유가 API (https://www.opinet.co.kr)
OPINET_KEY=your_opinet_key

# 공공데이터포털 경매 실거래 API (https://www.data.go.kr)
PUBLIC_DATA_API_KEY=your_public_data_api_key

# CORS (optional, defaults to https://agri.dooyg.store)
CORS_ORIGINS=https://agri.dooyg.store
